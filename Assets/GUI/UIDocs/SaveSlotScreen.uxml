                    <ui:Button text="Play" name="Play_1" class="control-button" />
                    <ui:Button text="Copy" name="Copy_1" class="control-button" />
                    <ui:Button text="Delete" name="Del_1" class="control-button" />
                </ui:VisualElement>
            </ui:VisualElement>
            <ui:VisualElement name="SavePanel2" class="save-panel" style="flex-grow: 1;">
                <ui:Label text="Save 3" name="Save2_Label" />
